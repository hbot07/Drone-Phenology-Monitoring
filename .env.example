# Drone Phenology Monitoring pipeline settings.
# Copy this file to .env and edit the paths for your machine.

# Cleaned orthomosaic input folder containing one .tif per date.
DPM_OM_DIR=input/input_om_sit

# Optional run/output names. If DPM_OUTPUT_DIR is empty, the pipeline writes to output/<run_name>.
DPM_RUN_NAME=example_sit_run
DPM_OUTPUT_DIR=output/example_sit_run

# Detectree2 model. Leave empty to auto-discover the first .pth under input/detectree_models/.
DPM_MODEL_PATH=input/detectree_models/250312_flexi.pth

# Optional existing crown detections. Set this when Step 1 was already run.
DPM_CROWNS_DIR=

# Comma-separated stems to exclude, for example a bad orthomosaic date.
DPM_EXCLUDE_STEMS=

# Steps to run: 0 discover, 1 detect crowns, 2 track, 3 phenology, 4 viewer.
DPM_STEPS=0,1,2,3,4

# Conda environments.
DPM_BASE_ENV=dpm-detectree
DPM_TRACKING_ENV=dpm-tracking

# Detectree2/tiling options.
DPM_DEVICE=cpu
DPM_THREADS=6
DPM_TILE_WIDTH=25
DPM_TILE_HEIGHT=25
DPM_TILE_BUFFER=15

# Tracking options.
DPM_ALIGN_METHOD=pcc_tiled
DPM_BASE_THRESHOLD_TAG=conf_0p45
DPM_ALIGN_THRESHOLD_TAG=conf_0p65
DPM_MIN_PARTIAL_LEN=5
DPM_MIN_PARTIAL_RATIO=0.9

# Viewer option.
DPM_UNDERLAY_OM=last
